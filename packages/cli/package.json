{
  "name": "universal-mcp-toolkit",
  "version": "1.6.27",
  "type": "module",
  "description": "35 prebuilt MCP (Model Context Protocol) servers — unified CLI for discovery, configuration, and runtime. Use with Claude Desktop, Cursor, Cline, and any MCP client.",
  "license": "MIT",
  "bin": {
    "umt": "./dist/index.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Markgatcha/universal-mcp-toolkit.git"
  },
  "homepage": "https://github.com/Markgatcha/universal-mcp-toolkit#readme",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "build:fast": "tsup src/index.ts --format esm --clean",
    "dev": "tsx watch src/index.ts",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rimraf dist"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "ai-tools",
    "ai-agent",
    "tool-calling",
    "claude",
    "cursor",
    "cline",
    "windsurf",
    "llm",
    "agent",
    "typescript",
    "cli",
    "commander",
    "developer-tools",
    "developer-experience",
    "monorepo",
    "terminal",
    "anthropic"
  ],
  "sideEffects": false,
  "dependencies": {
    "chalk": "^5.6.2",
    "cli-table3": "^0.6.5",
    "commander": "^15.0.0",
    "inquirer": "^14.0.2",
    "ora": "^9.4.0"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
