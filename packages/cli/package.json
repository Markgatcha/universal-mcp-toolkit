{
  "name": "universal-mcp-toolkit",
  "version": "1.3.0",
  "type": "module",
  "description": "A beautiful unified CLI for discovering, configuring, and running universal-mcp-toolkit MCP servers.",
  "license": "MIT",
  "bin": {
    "umt": "./dist/index.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Markgatcha/universal-mcp-toolkit.git"
  },
  "homepage": "https://github.com/Markgatcha/universal-mcp-toolkit#readme",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "dev": "tsx watch src/index.ts",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "clean": "rimraf dist"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ai",
    "developer-tools",
    "typescript",
    "cli",
    "commander",
    "terminal",
    "developer-experience"
  ],
  "dependencies": {
    "chalk": "^5.6.2",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.3",
    "ora": "^9.3.0",
    "inquirer": "^13.3.0"
  },
  "engines": {
    "node": ">=20.11.0",
    "bun": ">=1.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
