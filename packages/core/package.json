{
  "name": "@universal-mcp-toolkit/core",
  "version": "0.1.0",
  "type": "module",
  "description": "Shared runtime, validation, logging, transport, and DX primitives for universal-mcp-toolkit.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/universal-mcp-toolkit/universal-mcp-toolkit.git"
  },
  "homepage": "https://github.com/universal-mcp-toolkit/universal-mcp-toolkit#readme",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "dev": "tsx watch src/index.ts",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "clean": "rimraf dist"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ai",
    "developer-tools",
    "typescript",
    "core",
    "sdk",
    "transports",
    "zod",
    "pino"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "pino": "^10.3.1",
    "zod": "^4.3.6"
  }
}
