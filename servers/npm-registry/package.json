{
  "name": "@universal-mcp-toolkit/server-npm-registry",
  "version": "0.2.0",
  "type": "module",
  "description": "Package metadata, search, and version tools for the npm registry.",
  "license": "MIT",
  "bin": {
    "umt-npm-registry": "./dist/index.mjs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Markgatcha/universal-mcp-toolkit.git"
  },
  "homepage": "https://github.com/Markgatcha/universal-mcp-toolkit#readme",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    ".well-known"
  ],
  "scripts": {
    "build": "tsdown src/index.ts --format esm --dts --clean",
    "dev": "tsx watch src/index.ts",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "clean": "rimraf dist"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ai",
    "developer-tools",
    "typescript",
    "npm",
    "registry",
    "packages",
    "versions"
  ],
  "dependencies": {
    "@universal-mcp-toolkit/core": "workspace:*",
    "zod": "4.4.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
