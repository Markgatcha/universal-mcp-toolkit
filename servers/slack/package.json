{
  "name": "@universal-mcp-toolkit/server-slack",
  "version": "0.2.0",
  "type": "module",
  "description": "Channel lookup, history, and messaging tools for Slack workspaces.",
  "license": "MIT",
  "bin": {
    "umt-slack": "./dist/index.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Markgatcha/universal-mcp-toolkit.git"
  },
  "homepage": "https://github.com/Markgatcha/universal-mcp-toolkit#readme",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    ".well-known"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "dev": "tsx watch src/index.ts",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "clean": "rimraf dist"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ai",
    "developer-tools",
    "typescript",
    "slack",
    "chatops",
    "messaging",
    "channels"
  ],
  "dependencies": {
    "@universal-mcp-toolkit/core": "workspace:*",
    "zod": "4.4.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
