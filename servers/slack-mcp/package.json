{
  "name": "@contextcore/mcp-slack",
  "version": "1.2.0",
  "type": "module",
  "description": "Full Slack workspace integration with channels, messages, users, and files",
  "license": "MIT",
  "bin": {
    "umt-slack": "./dist/index.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/universal-mcp-toolkit/universal-mcp-toolkit.git"
  },
  "homepage": "https://github.com/universal-mcp-toolkit/universal-mcp-toolkit#readme",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    ".well-known"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "dev": "tsx watch src/index.ts",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "clean": "rimraf dist"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ai",
    "developer-tools",
    "typescript",
    "slack",
    "workspace",
    "messaging"
  ],
  "dependencies": {
    "@slack/web-api": "^7.8.0",
    "@universal-mcp-toolkit/core": "workspace:0.1.0",
    "zod": "^4.3.6"
  },
  "publishConfig": {
    "access": "public"
  }
}