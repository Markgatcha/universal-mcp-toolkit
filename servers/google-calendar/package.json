{
  "name": "@universal-mcp-toolkit/server-google-calendar",
  "version": "0.1.0",
  "type": "module",
  "description": "Calendar and event planning tools for Google Calendar.",
  "license": "MIT",
  "bin": {
    "umt-google-calendar": "./dist/index.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/universal-mcp-toolkit/universal-mcp-toolkit.git"
  },
  "homepage": "https://github.com/universal-mcp-toolkit/universal-mcp-toolkit#readme",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    ".well-known"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "dev": "tsx watch src/index.ts",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "clean": "rimraf dist"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ai",
    "developer-tools",
    "typescript",
    "google-calendar",
    "calendar",
    "events",
    "scheduling"
  ],
  "dependencies": {
    "@universal-mcp-toolkit/core": "workspace:0.1.0",
    "zod": "^4.3.6"
  }
}
