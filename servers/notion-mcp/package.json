{
  "name": "@contextcore/mcp-notion",
  "version": "1.2.0",
  "type": "module",
  "description": "Full Notion workspace integration — search, create, update pages and databases.",
  "license": "MIT",
  "bin": {
    "umt-notion": "./dist/index.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/universal-mcp-toolkit/universal-mcp-toolkit.git"
  },
  "homepage": "https://github.com/universal-mcp-toolkit/universal-mcp-toolkit#readme",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    ".well-known"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "dev": "tsx watch src/index.ts",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "clean": "rimraf dist"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ai",
    "developer-tools",
    "typescript",
    "notion",
    "knowledge-base",
    "docs",
    "wiki"
  ],
  "dependencies": {
    "@notionhq/client": "^2.3.0",
    "@universal-mcp-toolkit/core": "workspace:0.1.0",
    "zod": "^4.3.6"
  },
  "publishConfig": {
    "access": "public"
  }
}
