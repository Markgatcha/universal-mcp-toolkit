{
  "$schema": "https://json.schemastore.org/json",
  "name": "github",
  "title": "GitHub MCP Server",
  "description": "Repository search, pull request lookup, workflow run inspection, repository resources, and triage prompts for GitHub.",
  "version": "0.1.0",
  "packageName": "@universal-mcp-toolkit/server-github",
  "homepage": "https://github.com/universal-mcp-toolkit/universal-mcp-toolkit#readme",
  "repositoryUrl": "https://github.com/universal-mcp-toolkit/universal-mcp-toolkit",
  "documentationUrl": "https://github.com/universal-mcp-toolkit/universal-mcp-toolkit/tree/main/servers/github",
  "transports": [
    "stdio",
    "sse"
  ],
  "authentication": {
    "mode": "environment-variables",
    "required": [
      "GITHUB_TOKEN"
    ]
  },
  "capabilities": {
    "tools": true,
    "resources": true,
    "prompts": true
  },
  "tools": [
    "get_pull_request",
    "list_workflow_runs",
    "search_repositories"
  ],
  "resources": [
    "repository"
  ],
  "prompts": [
    "triage_pull_request"
  ],
  "configuration": {
    "optionalEnvironmentVariables": [
      "GITHUB_DEFAULT_OWNER",
      "GITHUB_DEFAULT_REPO",
      "GITHUB_API_BASE_URL"
    ],
    "repositoryDefaults": "Set GITHUB_DEFAULT_OWNER and GITHUB_DEFAULT_REPO together to omit owner/repo on repo-scoped tools.",
    "enterpriseSupport": "Set GITHUB_API_BASE_URL to target GitHub Enterprise Server."
  },
  "resourceTemplates": [
    {
      "name": "repository",
      "uriTemplate": "github://repos/{owner}/{repo}"
    }
  ],
  "promptExamples": [
    {
      "name": "triage_pull_request",
      "arguments": {
        "owner": "octo-org",
        "repo": "hello-world",
        "pullNumber": 42,
        "focus": "merge-readiness"
      }
    }
  ],
  "tags": [
    "github",
    "pull-requests",
    "actions",
    "repository-search",
    "workflow-runs",
    "enterprise"
  ]
}
