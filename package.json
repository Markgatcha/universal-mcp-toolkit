{
  "name": "universal-mcp-toolkit-monorepo",
  "version": "1.3.0",
  "private": true,
  "type": "module",
  "description": "The canonical open-source monorepo for production-ready MCP servers.",
  "license": "MIT",
  "packageManager": "pnpm@11.17.0",
  "engines": {
    "node": ">=20.11.0",
    "pnpm": ">=11.0.0",
    "bun": ">=1.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Markgatcha/universal-mcp-toolkit.git"
  },
  "bugs": {
    "url": "https://github.com/Markgatcha/universal-mcp-toolkit/issues"
  },
  "homepage": "https://github.com/Markgatcha/universal-mcp-toolkit#readme",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ai",
    "developer-tools",
    "typescript",
    "monorepo",
    "turborepo",
    "developer-experience"
  ],
  "scripts": {
    "build": "node scripts/run-turbo.mjs build",
    "dev": "node scripts/run-turbo.mjs dev --parallel",
    "lint": "node scripts/run-turbo.mjs lint",
    "typecheck": "node scripts/run-turbo.mjs typecheck",
    "test": "node scripts/run-turbo.mjs test",
    "clean": "node scripts/run-turbo.mjs clean && rimraf node_modules .turbo",
    "doctor": "corepack pnpm --filter universal-mcp-toolkit exec umt doctor",
    "umt": "bunx umt",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "corepack pnpm build && corepack pnpm test && changeset publish"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.1",
    "@types/dockerode": "^4.0.1",
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.1",
    "rimraf": "^6.1.3",
    "tsdown": "^0.22.14",
    "tsx": "^4.23.1",
    "turbo": "^2.10.6",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
